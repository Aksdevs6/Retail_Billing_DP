{
  "info": {
    "name": "Retail Billing System - API Tests",
    "_postman_id": "textile-billing-api",
    "description": "Complete API test collection for Retail Billing System (Textile Shop). Import this file into Postman to test all endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" }
  ],
  "item": [

    {
      "name": "PRODUCT APIs",
      "item": [

        {
          "name": "1. Get All Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products",
            "description": "Returns list of all products in the shop"
          }
        },

        {
          "name": "2. Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/1",
            "description": "Returns a single product by its ID"
          }
        },

        {
          "name": "3. Add New Product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Silk Saree\",\n  \"price\": 1500.00,\n  \"quantity\": 25,\n  \"gstPercent\": 12.0\n}"
            },
            "description": "Adds a new product. All fields required except gstPercent (defaults to 5)."
          }
        },

        {
          "name": "4. Update Product",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/products/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cotton Saree (Premium)\",\n  \"price\": 950.00,\n  \"quantity\": 45,\n  \"gstPercent\": 5.0\n}"
            },
            "description": "Updates an existing product by ID"
          }
        },

        {
          "name": "5. Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/products/5",
            "description": "Deletes a product by ID. Will fail if product is used in existing bills."
          }
        },

        {
          "name": "6. Search Products by Name",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/search?name=cotton",
            "description": "Case-insensitive search by product name"
          }
        },

        {
          "name": "7. Low Stock Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/low-stock?threshold=10",
            "description": "Products with quantity below threshold (default 10)"
          }
        },

        {
          "name": "8. Add Product - Validation Error Test",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"price\": -50,\n  \"quantity\": -1\n}"
            },
            "description": "Should return 400 with validation error messages"
          }
        }

      ]
    },

    {
      "name": "BILLING APIs",
      "item": [

        {
          "name": "1. Create Bill (Simple - 2 items)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bills",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"discountPercent\": 0,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 2 },\n    { \"productId\": 3, \"quantity\": 1 }\n  ]\n}"
            },
            "description": "Creates a bill with 2 Cotton Sarees + 1 Linen Kurta. Stock is auto-reduced."
          }
        },

        {
          "name": "2. Create Bill (With Discount)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bills",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"discountPercent\": 10,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 1 },\n    { \"productId\": 2, \"quantity\": 2 },\n    { \"productId\": 4, \"quantity\": 1 }\n  ]\n}"
            },
            "description": "Creates a bill with 10% discount applied"
          }
        },

        {
          "name": "3. Create Bill - Insufficient Stock Test",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bills",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"discountPercent\": 0,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 9999 }\n  ]\n}"
            },
            "description": "Should return 400: Insufficient stock error"
          }
        },

        {
          "name": "4. Create Bill - Invalid Product ID Test",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bills",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"discountPercent\": 0,\n  \"items\": [\n    { \"productId\": 9999, \"quantity\": 1 }\n  ]\n}"
            },
            "description": "Should return 404: Product not found"
          }
        },

        {
          "name": "5. Get All Bills",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bills",
            "description": "Returns all bills with their items"
          }
        },

        {
          "name": "6. Get Bill by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bills/1",
            "description": "Returns a specific bill with full item details"
          }
        }

      ]
    }

  ]
}
